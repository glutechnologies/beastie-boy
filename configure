#!/bin/sh
# Standard configure entrypoint for Beastie-Boy.
set -eu

PROJECT_ROOT="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"
CONFIG_MK="$PROJECT_ROOT/config.mk"

QUIET=0
PREFIX="/usr/local"
CC_BIN="${CC:-gcc}"
CPPFLAGS_IN="${CPPFLAGS:-}"
CFLAGS_IN="${CFLAGS:-}"
LDFLAGS_IN="${LDFLAGS:-}"

usage() {
  cat <<'EOF'
Usage: ./configure [options]

Options:
  --prefix=PATH        Installation prefix (stored in config.mk)
  --quiet              Reduce output
  -h, --help           Show this help message
EOF
}

log() {
  if [ "$QUIET" -eq 0 ]; then
    printf '%s\n' "$*"
  fi
}

fail() {
  printf 'configure: error: %s\n' "$*" >&2
  exit 1
}

require_cmd() {
  cmd="$1"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    fail "missing required command: $cmd"
  fi
}

pkg_config_flags() {
  pkg="$1"
  kind="$2"

  if ! command -v pkg-config >/dev/null 2>&1; then
    return 1
  fi
  if ! pkg-config --exists "$pkg"; then
    return 1
  fi

  case "$kind" in
    cflags) pkg-config --cflags "$pkg" ;;
    libs) pkg-config --libs "$pkg" ;;
    *) return 1 ;;
  esac
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --prefix=*)
      PREFIX="${1#*=}"
      ;;
    --prefix)
      shift
      [ "$#" -gt 0 ] || fail "--prefix requires an argument"
      PREFIX="$1"
      ;;
    --quiet)
      QUIET=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      fail "unknown option: $1"
      ;;
  esac
  shift
done

require_cmd make
require_cmd "$CC_BIN"

PCAP_CFLAGS=""
PCAP_LIBS="-lpcap"
for pkg in libpcap pcap; do
  if cflags="$(pkg_config_flags "$pkg" cflags)"; then
    PCAP_CFLAGS="$cflags"
    PCAP_LIBS="$(pkg_config_flags "$pkg" libs)"
    break
  fi
done

MEMIF_CFLAGS=""
MEMIF_LIBS="-lmemif"
for pkg in libmemif memif; do
  if cflags="$(pkg_config_flags "$pkg" cflags)"; then
    MEMIF_CFLAGS="$cflags"
    MEMIF_LIBS="$(pkg_config_flags "$pkg" libs)"
    break
  fi
done

VAPI_CFLAGS=""
VAPI_LIBS="-lvapiclient"
for pkg in vapiclient vpp-api-client; do
  if cflags="$(pkg_config_flags "$pkg" cflags)"; then
    VAPI_CFLAGS="$cflags"
    VAPI_LIBS="$(pkg_config_flags "$pkg" libs)"
    break
  fi
done

TMP_DIR="$(mktemp -d)"
cleanup() {
  rm -rf "$TMP_DIR"
}
trap cleanup EXIT INT TERM

check_compile() {
  name="$1"
  code="$2"
  cflags_extra="$3"
  libs_extra="$4"

  log "checking $name"
  printf '%s\n' "$code" >"$TMP_DIR/conftest.c"
  if "$CC_BIN" $CPPFLAGS_IN $CFLAGS_IN $cflags_extra \
      -o "$TMP_DIR/conftest" "$TMP_DIR/conftest.c" \
      $LDFLAGS_IN $libs_extra >"$TMP_DIR/conftest.out" 2>&1; then
    log "  -> ok"
    return 0
  fi

  sed 's/^/  /' "$TMP_DIR/conftest.out" >&2 || true
  fail "$name failed"
}

check_headers_only() {
  name="$1"
  code="$2"
  cflags_extra="$3"

  log "checking $name"
  printf '%s\n' "$code" >"$TMP_DIR/conftest.c"
  if "$CC_BIN" $CPPFLAGS_IN $CFLAGS_IN $cflags_extra \
      -c -o "$TMP_DIR/conftest.o" "$TMP_DIR/conftest.c" \
      >"$TMP_DIR/conftest.out" 2>&1; then
    log "  -> ok"
    return 0
  fi

  sed 's/^/  /' "$TMP_DIR/conftest.out" >&2 || true
  fail "$name failed"
}

check_libmemif_api() {
  header="${LIBMEMIF_HEADER:-/usr/include/libmemif.h}"
  library="${LIBMEMIF_LIBRARY:-/lib/libmemif.so}"

  [ -e "$library" ] || fail "missing required file: $library"
  [ -e "$header" ] || fail "missing required file: $header"

  grep -Eq 'int memif_create \(memif_conn_handle_t \*conn, memif_conn_args_t \*args,' "$header" \
    || fail "libmemif API check failed: missing memif_create signature in $header"
  grep -Eq 'int memif_create_socket \(memif_socket_handle_t \*sock,' "$header" \
    || fail "libmemif API check failed: missing memif_create_socket signature in $header"
  grep -Eq 'int memif_poll_event \(memif_socket_handle_t sock, int timeout\);' "$header" \
    || fail "libmemif API check failed: missing memif_poll_event signature in $header"
  grep -Eq 'int memif_cancel_poll_event \(memif_socket_handle_t sock\);' "$header" \
    || fail "libmemif API check failed: missing memif_cancel_poll_event signature in $header"
}

check_compile \
  "libpcap + libmemif headers and linker flags" \
  '#include <pcap/pcap.h>
#include <libmemif.h>
int main(void) { memif_socket_handle_t s = 0; (void)s; return 0; }' \
  "$PCAP_CFLAGS $MEMIF_CFLAGS" \
  "$PCAP_LIBS $MEMIF_LIBS -lpthread"

check_compile \
  "libvapi linker flags" \
  '#include <vapi/vapi.h>
int main(void) { return (int)VAPI_OK; }' \
  "$VAPI_CFLAGS" \
  "$VAPI_LIBS -lpthread"

check_headers_only \
  "libvapi API headers" \
  '#include <vapi/vapi.h>
#include <vapi/vpe.api.vapi.h>
int main(void) { return 0; }' \
  "$VAPI_CFLAGS"

log "checking libmemif API compatibility"
check_libmemif_api

cat >"$CONFIG_MK" <<EOF
# Generated by ./configure. Do not edit by hand.
PREFIX := $PREFIX
EXTRA_CPPFLAGS :=
EXTRA_CFLAGS :=
EXTRA_LDFLAGS := $LDFLAGS_IN
PCAP_CFLAGS := $PCAP_CFLAGS
PCAP_LIBS := $PCAP_LIBS
MEMIF_CFLAGS := $MEMIF_CFLAGS
MEMIF_LIBS := $MEMIF_LIBS
VAPI_CFLAGS := $VAPI_CFLAGS
VAPI_LIBS := $VAPI_LIBS
EOF

log "configuration completed successfully"
log "wrote $CONFIG_MK"
