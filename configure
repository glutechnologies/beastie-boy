#!/bin/sh
# Standard configure entrypoint for Beastie-Boy.
set -eu

PROJECT_ROOT="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"
CONFIG_MK="$PROJECT_ROOT/config.mk"

QUIET=0
PREFIX="/usr/local"
CC_BIN="${CC:-gcc}"
CPPFLAGS_IN="${CPPFLAGS:-}"
CFLAGS_IN="${CFLAGS:-}"
LDFLAGS_IN="${LDFLAGS:-}"
ALLOW_UNSUPPORTED_VPP=0
SUPPORTED_VPP_SERIES="2506 2510 2602"

usage() {
  cat <<'EOF'
Usage: ./configure [options]

Options:
  --prefix=PATH        Installation prefix (stored in config.mk)
  --supported-vpp-series=LIST
                       Space or comma separated supported VPP API series
                       (example: 2410,2502,2506)
  --allow-unsupported-vpp
                       Continue even if detected VPP series is not supported
  --quiet              Reduce output
  -h, --help           Show this help message
EOF
}

log() {
  if [ "$QUIET" -eq 0 ]; then
    printf '%s\n' "$*"
  fi
}

log_check_start() {
  name="$1"
  if [ "$QUIET" -eq 0 ]; then
    printf '%-64s : ' "Checking $name"
  fi
}

log_check_result() {
  result="$1"
  if [ "$QUIET" -eq 0 ]; then
    printf '%s\n' "$result"
  fi
}

fail() {
  printf 'configure: error: %s\n' "$*" >&2
  exit 1
}

require_cmd() {
  cmd="$1"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    fail "missing required command: $cmd"
  fi
}

pkg_config_flags() {
  pkg="$1"
  kind="$2"

  if ! command -v pkg-config >/dev/null 2>&1; then
    return 1
  fi
  if ! pkg-config --exists "$pkg"; then
    return 1
  fi

  case "$kind" in
    cflags) pkg-config --cflags "$pkg" ;;
    libs) pkg-config --libs "$pkg" ;;
    *) return 1 ;;
  esac
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --prefix=*)
      PREFIX="${1#*=}"
      ;;
    --prefix)
      shift
      [ "$#" -gt 0 ] || fail "--prefix requires an argument"
      PREFIX="$1"
      ;;
    --quiet)
      QUIET=1
      ;;
    --supported-vpp-series=*)
      SUPPORTED_VPP_SERIES="${1#*=}"
      ;;
    --allow-unsupported-vpp)
      ALLOW_UNSUPPORTED_VPP=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      fail "unknown option: $1"
      ;;
  esac
  shift
done

SUPPORTED_VPP_SERIES="$(printf '%s\n' "$SUPPORTED_VPP_SERIES" | tr ',' ' ' | xargs)"

require_cmd make
require_cmd "$CC_BIN"

PCAP_CFLAGS=""
PCAP_LIBS="-lpcap"
for pkg in libpcap pcap; do
  if cflags="$(pkg_config_flags "$pkg" cflags)"; then
    PCAP_CFLAGS="$cflags"
    PCAP_LIBS="$(pkg_config_flags "$pkg" libs)"
    break
  fi
done

MEMIF_CFLAGS=""
MEMIF_LIBS="-lmemif"
for pkg in libmemif memif; do
  if cflags="$(pkg_config_flags "$pkg" cflags)"; then
    MEMIF_CFLAGS="$cflags"
    MEMIF_LIBS="$(pkg_config_flags "$pkg" libs)"
    break
  fi
done

VAPI_CFLAGS=""
VAPI_LIBS="-lvapiclient"
VAPI_PKG=""
for pkg in vapiclient vpp-api-client; do
  if cflags="$(pkg_config_flags "$pkg" cflags)"; then
    VAPI_CFLAGS="$cflags"
    VAPI_LIBS="$(pkg_config_flags "$pkg" libs)"
    VAPI_PKG="$pkg"
    break
  fi
done

VPP_API_VERSION="unknown"
VPP_SERIES="0"
if [ -n "$VAPI_PKG" ] && command -v pkg-config >/dev/null 2>&1; then
  VPP_API_VERSION="$(pkg-config --modversion "$VAPI_PKG" 2>/dev/null || true)"
fi

if [ "$VPP_API_VERSION" = "unknown" ] && command -v dpkg-query >/dev/null 2>&1; then
  for pkg in vpp-dev vpp libvppinfra-dev libvppinfra; do
    if dpkg-query -W -f='${Status}' "$pkg" 2>/dev/null | grep -q "install ok installed"; then
      VPP_API_VERSION="$(dpkg-query -W -f='${Version}' "$pkg" 2>/dev/null || true)"
      [ -n "$VPP_API_VERSION" ] || VPP_API_VERSION="unknown"
      break
    fi
  done
fi

if [ "$VPP_API_VERSION" != "unknown" ]; then
  if printf '%s\n' "$VPP_API_VERSION" | grep -Eq '^[0-9]+\.[0-9]+'; then
    VPP_MAJOR="$(printf '%s\n' "$VPP_API_VERSION" | sed -E 's/^([0-9]+)\..*/\1/')"
    VPP_MINOR="$(printf '%s\n' "$VPP_API_VERSION" | sed -E 's/^[0-9]+\.([0-9]+).*/\1/')"
    VPP_MINOR_PADDED="$(printf '%02d' "$VPP_MINOR")"
    VPP_SERIES="${VPP_MAJOR}${VPP_MINOR_PADDED}"
  fi
fi

TMP_DIR="$(mktemp -d)"
cleanup() {
  rm -rf "$TMP_DIR"
}
trap cleanup EXIT INT TERM

check_compile() {
  name="$1"
  code="$2"
  cflags_extra="$3"
  libs_extra="$4"

  log_check_start "$name"
  printf '%s\n' "$code" >"$TMP_DIR/conftest.c"
  if "$CC_BIN" $CPPFLAGS_IN $CFLAGS_IN $cflags_extra \
      -o "$TMP_DIR/conftest" "$TMP_DIR/conftest.c" \
      $LDFLAGS_IN $libs_extra >"$TMP_DIR/conftest.out" 2>&1; then
    log_check_result "OK"
    return 0
  fi

  log_check_result "FAIL"
  sed 's/^/  /' "$TMP_DIR/conftest.out" >&2 || true
  fail "$name failed"
}

check_headers_only() {
  name="$1"
  code="$2"
  cflags_extra="$3"

  log_check_start "$name"
  printf '%s\n' "$code" >"$TMP_DIR/conftest.c"
  if "$CC_BIN" $CPPFLAGS_IN $CFLAGS_IN $cflags_extra \
      -c -o "$TMP_DIR/conftest.o" "$TMP_DIR/conftest.c" \
      >"$TMP_DIR/conftest.out" 2>&1; then
    log_check_result "OK"
    return 0
  fi

  log_check_result "FAIL"
  sed 's/^/  /' "$TMP_DIR/conftest.out" >&2 || true
  fail "$name failed"
}

check_libmemif_api() {
  header="${LIBMEMIF_HEADER:-/usr/include/libmemif.h}"
  library="${LIBMEMIF_LIBRARY:-/lib/libmemif.so}"

  [ -e "$library" ] || fail "missing required file: $library"
  [ -e "$header" ] || fail "missing required file: $header"

  grep -Eq 'int memif_create \(memif_conn_handle_t \*conn, memif_conn_args_t \*args,' "$header" \
    || fail "libmemif API check failed: missing memif_create signature in $header"
  grep -Eq 'int memif_create_socket \(memif_socket_handle_t \*sock,' "$header" \
    || fail "libmemif API check failed: missing memif_create_socket signature in $header"
  grep -Eq 'int memif_poll_event \(memif_socket_handle_t sock, int timeout\);' "$header" \
    || fail "libmemif API check failed: missing memif_poll_event signature in $header"
  grep -Eq 'int memif_cancel_poll_event \(memif_socket_handle_t sock\);' "$header" \
    || fail "libmemif API check failed: missing memif_cancel_poll_event signature in $header"
}

check_compile \
  "libpcap + libmemif headers and linker flags" \
  '#include <pcap/pcap.h>
#include <libmemif.h>
int main(void) { memif_socket_handle_t s = 0; (void)s; return 0; }' \
  "$PCAP_CFLAGS $MEMIF_CFLAGS" \
  "$PCAP_LIBS $MEMIF_LIBS -lpthread"

check_compile \
  "libvapi linker flags" \
  '#include <vapi/vapi.h>
int main(void) { return (int)VAPI_OK; }' \
  "$VAPI_CFLAGS" \
  "$VAPI_LIBS -lpthread"

check_headers_only \
  "libvapi API headers" \
  '#include <vapi/vapi.h>
#include <vapi/vpe.api.vapi.h>
int main(void) { return 0; }' \
  "$VAPI_CFLAGS"

log_check_start "libmemif API compatibility"
check_libmemif_api
log_check_result "OK"

log_check_start "supported VPP API series"
if [ "$VPP_SERIES" = "0" ]; then
  log_check_result "warning"
  log "  could not determine VPP API series from pkg-config version '$VPP_API_VERSION'"
  log "  continuing with BOY_VPP_API_SERIES=0"
else
  VPP_SERIES_SUPPORTED=0
  for series in $SUPPORTED_VPP_SERIES; do
    if [ "$series" = "$VPP_SERIES" ]; then
      VPP_SERIES_SUPPORTED=1
      break
    fi
  done
  if [ "$VPP_SERIES_SUPPORTED" -eq 1 ]; then
    log_check_result "OK"
    log "  detected VPP series: $VPP_SERIES (version: $VPP_API_VERSION)"
  elif [ "$ALLOW_UNSUPPORTED_VPP" -eq 1 ]; then
    log_check_result "warning"
    log "  detected unsupported VPP series $VPP_SERIES (version: $VPP_API_VERSION)"
  else
    log_check_result "failed"
    fail "detected unsupported VPP series $VPP_SERIES (version: $VPP_API_VERSION), supported: $SUPPORTED_VPP_SERIES"
  fi
fi

cat >"$CONFIG_MK" <<EOF
# Generated by ./configure. Do not edit by hand.
PREFIX := $PREFIX
EXTRA_CPPFLAGS :=
EXTRA_CFLAGS :=
EXTRA_LDFLAGS := $LDFLAGS_IN
PCAP_CFLAGS := $PCAP_CFLAGS
PCAP_LIBS := $PCAP_LIBS
MEMIF_CFLAGS := $MEMIF_CFLAGS
MEMIF_LIBS := $MEMIF_LIBS
VAPI_CFLAGS := $VAPI_CFLAGS
VAPI_LIBS := $VAPI_LIBS
VPP_API_VERSION := $VPP_API_VERSION
VPP_API_SERIES := $VPP_SERIES
VPP_COMPAT_CPPFLAGS := -DBOY_VPP_API_SERIES=$VPP_SERIES -DBOY_VPP_API_VERSION_STR=\"$VPP_API_VERSION\"
EOF

log "configuration completed successfully"
log "wrote $CONFIG_MK"
